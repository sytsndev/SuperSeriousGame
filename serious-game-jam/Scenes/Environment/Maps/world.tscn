[sub_resource type="Shader" id="Shader_7gwe0"]
code = "
// NOTE: Shader automatically converted from Godot Engine 4.7.stable's PanoramaSkyMaterial.

shader_type sky;

uniform sampler2D source_panorama : filter_linear, source_color, hint_default_black;
uniform float speed = 0.002;


void sky() {
	vec2 skyCoords = vec2(SKY_COORDS.x + TIME * speed, SKY_COORDS.y);
	
	COLOR = texture(source_panorama, skyCoords).rgb;
}
"

